re details for the 14B variant specifically. The official technical report is available on arXiv (2409.12186)."],"durationSeconds":8.139135833999141,"searchCount":1},"sourceToolAssistantUUID":"4186cc6d-9da2-4ad4-81d9-945d6f9564cd","userType":"external","entrypoint":"cli","cwd":"/Users/gg/Work/Yogi","sessionId":"d8d6b712-ec33-4776-a194-d9a72216a25f","version":"2.1.183","gitBranch":"main","slug":"bright-wondering-lantern"}
